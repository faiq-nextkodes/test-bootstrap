<%= form_with model: task, local: true do |form| %>
  <div class="mb-3">
    <div class="row">
    <button class="btn btn-primary fw-bold">Title</button>
    </div>
    <%= form.text_field :title, class: "form-control" %>
  </div>
    <div class="text-center">
  <%= form.submit "Create Task", class: "btn btn-success" %>
  </div>
<% end %>